# ─────────────────────────────────────────────────────────
# AWS Cognito Authentication – Environment Variables
# ─────────────────────────────────────────────────────────
# Set VITE_USE_MOCK_AUTH=true to test without AWS credentials.
# Set VITE_USE_MOCK_AUTH=false to use real AWS Cognito.
# ─────────────────────────────────────────────────────────

# ── AWS Region ──
VITE_AWS_REGION=ap-south-1

# ── AWS Cognito User Pool ──
# Find these in: AWS Console → Cognito → User Pools → your pool → App integration
VITE_AWS_USER_POOL_ID=ap-south-1_U1K91wCSu
VITE_AWS_USER_POOL_CLIENT_ID=ivgfsak25uasvr7j93342qhvb

# ── Cognito Hosted UI / OAuth (Required for Google Sign-In) ──
# Format: <prefix>.auth.<region>.amazoncognito.com (no https://)
VITE_AWS_COGNITO_DOMAIN=ap-south-1u1k91wcsu.auth.ap-south-1.amazoncognito.com

# ── Redirect URLs (must match what's set in Cognito App Client) ──
VITE_AWS_REDIRECT_SIGN_IN=http://localhost:5173/
VITE_AWS_REDIRECT_SIGN_OUT=http://localhost:5173/
