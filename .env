# ─────────────────────────────────────────────────────────
# AWS Cognito Authentication – Environment Variables
# ─────────────────────────────────────────────────────────

# ── AWS Region ──
VITE_AWS_REGION=ap-south-1

# ── AWS Cognito User Pool ──
# Verify these in: AWS Console → Cognito → User Pools → your pool
# ⚠ Two different pools existed in git history. Use ONLY one.
VITE_AWS_USER_POOL_ID=ap-south-1_3rr8tQ8aX
VITE_AWS_USER_POOL_CLIENT_ID=5b2gdlk67706hr63m8rae3bouo

# ── Cognito Hosted UI / OAuth (Required for Google Sign-In) ──
# ⚠ ACTION REQUIRED: Copy the exact domain from:
#   AWS Console → Cognito → User Pools → [your pool] → App integration → Domain
#
# Format: <custom-prefix>.auth.ap-south-1.amazoncognito.com  (no https://)
# Example: myapp.auth.ap-south-1.amazoncognito.com
#
# The value below may be WRONG. "ap-south-13rr8tq8ax" looks like a
# concatenation of region+poolId, NOT a valid Cognito domain prefix.
# Replace it with the real prefix from the console.
VITE_AWS_COGNITO_DOMAIN=ap-south-13rr8tq8ax.auth.ap-south-1.amazoncognito.com

# ── Redirect URLs (must match what's set in Cognito App Client) ──
VITE_AWS_REDIRECT_SIGN_IN=http://localhost:5173/
VITE_AWS_REDIRECT_SIGN_OUT=http://localhost:5173/
