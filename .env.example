# ─────────────────────────────────────────────────────────
# AWS Cognito Authentication – Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────

# ── AWS Region ──
VITE_AWS_REGION=ap-south-1

# ── AWS Cognito User Pool ──
# Find in: AWS Console → Cognito → User Pools → your pool → Overview
VITE_AWS_USER_POOL_ID=ap-south-1_XXXXXXXXX
VITE_AWS_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Cognito Hosted UI / OAuth (Required for Google Sign-In) ──
# Find in: AWS Console → Cognito → User Pools → your pool → App integration → Domain
# Format: <custom-prefix>.auth.<region>.amazoncognito.com  (no https://)
VITE_AWS_COGNITO_DOMAIN=your-prefix.auth.ap-south-1.amazoncognito.com

# ── Redirect URLs (must match Cognito App Client Callback / Sign-out URLs) ──
VITE_AWS_REDIRECT_SIGN_IN=http://localhost:5173/
VITE_AWS_REDIRECT_SIGN_OUT=http://localhost:5173/
