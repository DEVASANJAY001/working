# AWS Cognito Environment Configuration
# Copy this file to .env and configure the placeholders with your actual AWS Cognito settings.

# Enable Mock Mode to test locally without AWS Credentials. Set to "false" to use real Cognito.
VITE_USE_MOCK_AUTH=true

# AWS Cognito User Pool details
VITE_AWS_REGION=us-east-1
VITE_AWS_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_AWS_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Cognito Hosted UI Configuration (Required for Google Sign-In)
VITE_AWS_COGNITO_DOMAIN=your-auth-domain.auth.us-east-1.amazoncognito.com
VITE_AWS_REDIRECT_SIGN_IN=http://localhost:5173/
VITE_AWS_REDIRECT_SIGN_OUT=http://localhost:5173/

# Google OAuth Configuration (Reference for AWS Cognito Federated Identity Provider)
# Note: Google Client IDs are configured directly inside AWS Cognito User Pool console.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
